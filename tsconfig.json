{
  // FROZEN toolchain config (Phase 0.5). Any change to target / module /
  // moduleResolution / lib — or the pinned typescript version in
  // package.json — can shift the emitted JS and is a deliberate RE-BASELINE
  // event (see docs/design-engine-generalization.md, re-baseline register).
  //
  // target es2022 == what the browsers and Node 22 already run, so tsc does
  // NO downleveling and injects NO helpers: the emit is behaviorally
  // identical to the source. That identity is what the golden master polices
  // when the build first lands. allowJs is on so today's pure-.js source
  // passes through unchanged; Phase 1 renames files to .ts one at a time.
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable", "webworker"],
    "allowJs": true,
    "checkJs": false,
    "outDir": "dist",
    "rootDir": ".",
    "removeComments": false,
    "newLine": "lf",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["js/**/*", "sw.js"]
}
