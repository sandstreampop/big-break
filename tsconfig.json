{
  // FROZEN toolchain config (Phase 0.5). Any change to target / module /
  // moduleResolution / lib — or the pinned typescript version in
  // package.json — can shift the emitted JS and is a deliberate RE-BASELINE
  // event (regenerate the golden masters afterward).
  //
  // target es2022 == what the browsers and Node 22 already run, so tsc does
  // NO downleveling and injects NO helpers: the emit is behaviorally
  // identical to the source. That identity is what the golden master polices.
  // allowJs is now OFF (Phase 1 complete): every module under js/ is .ts.
  // sw.js is copied verbatim by the build (a standalone service worker with
  // no imports — no reason to run it through tsc).
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable", "webworker"],
    "allowJs": false,
    "checkJs": false,
    "outDir": "dist",
    "rootDir": ".",
    "removeComments": false,
    "newLine": "lf",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["js/**/*"]
}
