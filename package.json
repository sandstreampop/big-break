{
  "name": "big-break",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Big Break — a swipe-roguelike engine powering two games: a music-career game and a reality-show murder mystery.",
  "scripts": {
    "build": "node tools/build.mjs",
    "lint": "npm run build && node tools/lint-content.mjs",
    "smoke": "npm run build && node test/ui-smoke.mjs",
    "check": "npm run build && node tools/lint-content.mjs && node tools/simulate.mjs --check && node tools/mystery-sim.mjs --check && node test/ui-smoke.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "sim": "npm run build && node tools/simulate.mjs",
    "android": "npm run build && node tools/android/run.mjs",
    "android:quick": "npm run build && node tools/android/run.mjs --quick",
    "ios": "npm run build && node tools/ios/run.mjs",
    "ios:quick": "npm run build && node tools/ios/run.mjs --quick"
  },
  "devDependencies": {
    "playwright": "^1.56.1",
    "typescript": "5.7.3"
  }
}
